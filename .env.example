# Copy to .env and fill in.

# === Reddit (NO AUTH NEEDED — uses public JSON endpoints) ===
# Reddit's Responsible Builder Policy (Nov 2025) ended self-service API keys;
# new OAuth apps need ~7-day approval. We use the public JSON endpoints
# (`<reddit-url>.json`) instead, which require zero credentials.
#
# Only thing to set is the User-Agent. Reddit recommends format:
#   "<platform>:<app>:<version> (by /u/<your_username>)"
# A descriptive UA gets higher rate limits than the httpx/python default.
REDDIT_USER_AGENT=zomato-social-watch:0.1 (by /u/your_reddit_username)

# === Reddit WRITE — script-app credentials for the comment connector ===
# We read Reddit via public JSON (no auth). To WRITE comments we need a
# personal-use "script app" — instant credentials, no review queue.
# Setup (~5 min):
#   1. https://www.reddit.com/prefs/apps  →  "Create another app"
#   2. Choose **script** (NOT "web app"); name it; redirect URI = http://localhost
#   3. Copy the two opaque strings:
#        client_id     — under the app name (looks like "Abc12d-_xy")
#        client_secret — labeled "secret"
#   4. Use a throwaway Reddit account for username/password.
# Comments fire only via the dashboard's manual "Comment on Reddit"
# button — never automatically.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# === Twitter / X (free, via twscrape) — pick ONE auth path ===

# OPTION 1 (RECOMMENDED): cookie-based auth
# Why: no login flow, no captcha possible, no email IMAP setup.
# Steps:
#   1. Sign up / log in at https://x.com (a throwaway account is fine)
#   2. Open DevTools (Cmd+Opt+I on Mac, F12 on Windows)
#   3. Application tab → Cookies → https://x.com (in the left sidebar)
#   4. Find these two cookies, copy their values:
#        auth_token   (long hex-looking string, ~40 chars)
#        ct0          (long hex-looking string)
#   5. Paste below
# Cookies last ~30 days; refresh from browser when they expire.
TWITTER_COOKIE_USERNAME=
TWITTER_COOKIE_AUTH_TOKEN=
TWITTER_COOKIE_CT0=

# OPTION 2 (fallback): username/password + email IMAP
# Format: user:pass:email:emailapp_password  (comma-separate multiple accounts)
# Only used if cookies above are empty.
TWITTER_ACCOUNTS=

TWSCRAPE_DB=accounts.db

# === Gemini API (LLM provider for the classifier) ===
# Get a key at: https://aistudio.google.com/apikey  (free, instant)
# Free tier: 250 requests/day + 1M tokens/day on Gemini 2.5 Flash.
# Cost (if exceeded): $0.30/M input, $2.50/M output. ~$0.04 for our 170 posts.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# === LLM reply drafter (Phase 4) ===
# The "✨ Draft reply" button on each inbox row sends the post to an LLM
# with a Zomato-care system prompt; the LLM returns a ≤280-char draft
# reply, suggested tone, and routing channel. The operator edits in
# place, copies, and ships — human stays in the loop.
#
# Two providers supported. Whichever key is set wins. Gemini auto-wins
# the tie since it's free.
#
# 1) Gemini (recommended — already used by classifier).
#    Free 250 requests/day on Gemini 2.5 Flash, instant key, no cc.
#    The same GEMINI_API_KEY above powers this. Nothing else to set.
#
# 2) Anthropic Claude (alternative — slightly nicer tone).
#    ~$0.001 per draft on claude-haiku-4-5. $5 free credits.
#    Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# === Action channels — tiered routing (Phase 3+4) ===
# Each connector is independent: set whichever you want, leave the rest
# blank. Smoke-test what's configured with: `uv run python main.py test-actions`.
#
# The dispatcher applies TIERED ROUTING to each escalated post:
#
#   Tier 1  Sheets         every escalated post (P0/P1/P2 + tripwires)
#                          audit log. searchable, exportable, doesn't drown.
#   Tier 2  Email          P0 + P1 only. routed by audience tag.
#                          "team needs to action this" tier.
#   Tier 3  Slack+Discord  P0 with hard tripwires only (food safety,
#                          court FIR, sexual misconduct, privacy leak,
#                          regulatory threat, religious sensitivity).
#                          "wake someone up at 2am" tier.
#
# A founder mention alone won't trigger Slack — every angry consumer
# @-tags @deepigoyal, and we don't want to flood the war room.

# 1) Slack incoming webhook
#    https://api.slack.com/messaging/webhooks → New webhook → copy URL
SLACK_WEBHOOK_URL=

# 2) Discord incoming webhook
#    Channel → Edit → Integrations → Webhooks → New → copy URL
DISCORD_WEBHOOK_URL=

# 3) Email via SMTP (Gmail with App Password works out of the box)
#    Generate App Password: https://myaccount.google.com/apppasswords
#    EMAIL_TO accepts a comma-separated list (ops + founder office, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# 4) Google Sheets via Apps Script web-app webhook (no service account!)
#    See setup snippet in social_watch/actions/sheets.py — 3 minutes.
SHEETS_WEBHOOK_URL=

# 5) Linear ticket — durable workflow item per P0 post.
#    Slack tells you "wake up", a ticket is what gets *assigned and
#    closed*. Auto-fires on every P0 (any tripwire or none).
#    Setup (~2 min):
#      1. https://linear.app/settings/api → "Create new" personal API key
#      2. Get your team UUIDs (one per ops team):
#           curl -X POST https://api.linear.app/graphql \
#             -H "Authorization: <api-key>" \
#             -H "Content-Type: application/json" \
#             -d '{"query":"{ teams { nodes { id key name } } users { nodes { id name displayName } } }"}'
#         Copy the team UUIDs and the user UUIDs of your on-call leads.
#      3. Paste below. The default team catches anything that doesn't
#         match a per-playbook team. The maps are JSON.
LINEAR_API_KEY=
LINEAR_TEAM_ID=
# Per-playbook team routing. Owner-team strings come from
# social_watch/playbooks.py (e.g. "Trust & Safety", "Quality &
# Compliance", "Legal", "InfoSec", "PR + T&S", "Legal + Policy",
# "InfoSec + HR"). Map any of those to the appropriate Linear team UUID.
# Unmapped owner teams fall back to LINEAR_TEAM_ID above.
#   Example:
#     LINEAR_TEAMS={"Trust & Safety":"a1b2-...","Quality & Compliance":"c3d4-...","Legal":"e5f6-..."}
LINEAR_TEAMS=
# Per-playbook on-call assignee. Same key set as LINEAR_TEAMS, mapped
# to a Linear user UUID. Unmapped → ticket created unassigned.
#   Example:
#     LINEAR_ASSIGNEES={"Trust & Safety":"u1...","Legal":"u2..."}
LINEAR_ASSIGNEES=

# Optional — overrides the dashboard URL embedded in alerts (defaults to
# http://localhost:8000). Set this when running on Fly/Render/etc so the
# "Open dashboard" buttons in Slack/Discord/Email point at production.
DASHBOARD_BASE_URL=

# === Storage ===
DB_PATH=social_watch.db

# === Schedule ===
# Refresh interval in seconds for `main.py watch`. Spec requires <= 300.
REFRESH_INTERVAL=300

# === Action dispatchers (Phase 3) — at least one of Slack or Discord ===
# Both are free, take ~30 seconds to set up, and are not metered. The
# dispatcher fires to BOTH if both are configured (redundant connectors).
# A post is marked "actioned" if AT LEAST ONE channel returned ok.
#
# Smoke-test once you've pasted a URL below:
#     uv run python main.py test-actions

# --- Slack incoming webhook ---
# Steps:
#   1. Visit https://api.slack.com/messaging/webhooks
#   2. "Create your Slack app" → "From scratch" → name "Zomato Social Watch"
#   3. In the app, enable "Incoming Webhooks", click "Add New Webhook to
#      Workspace", pick a channel (e.g. #zomato-watch-p0), authorize.
#   4. Copy the URL (https://hooks.slack.com/services/...) and paste below.
SLACK_WEBHOOK_URL=

# --- Discord incoming webhook ---
# Steps:
#   1. In your Discord server, right-click the channel you want alerts in
#      → "Edit Channel" → "Integrations" → "Webhooks" → "New Webhook".
#   2. Name it "Zomato Social Watch", optionally pick an avatar.
#   3. Click "Copy Webhook URL" and paste below.
DISCORD_WEBHOOK_URL=

# Optional: where the dashboard is reachable, used for the "Open dashboard"
# link in messages. Defaults to http://localhost:8000.
DASHBOARD_BASE_URL=http://localhost:8000

# === Auto-reply policy (Phase μ) =========================================
# When enabled, the background sweep fires templated Twitter replies to
# *safe* customer-care posts (no tripwire, no abuse, no sarcasm) within
# minutes of arrival. This stops the "186 overdue" backlog from growing.
#
# Defense in depth (10 stacked guards in social_watch/auto_reply.py):
#   1. AUTO_REPLY_ENABLED — this env var. Default OFF.
#   2. Twitter only (Reddit threads are too public).
#   3. classification.auto_action_safe must be true.
#   4. priority_breakdown.tripwire_override must be false.
#   5. Audience must be exactly customer-care or ops.
#   6. 2-minute cooling-off so the LLM tripwire pass settles.
#   7. 1 reply per author per hour (no spam).
#   8. 10 replies per sweep × 12 cycles/hr = ≤ 120/hr.
#   9. Drain hard-cap at 200 per operator-run.
#  10. Server-side re-validation on drain (fresh tripwires re-checked).
#
# Set to 1 only after you've smoke-tested with AUTO_REPLY_DRY_RUN=1
# for one cycle and eyeballed the intended fires.
AUTO_REPLY_ENABLED=0
AUTO_REPLY_DRY_RUN=0
